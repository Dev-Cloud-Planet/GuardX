# ── Provider: "anthropic", "openrouter", or "ollama" (auto-detected if not set) ──
# GUARDX_PROVIDER=anthropic

# ── Anthropic (direct) ──
ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenRouter ──
# OPENROUTER_API_KEY=sk-or-xxxxx
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Ollama (local, zero cost) ──
# OLLAMA_MODEL=llama3.1              # Modelos: llama3.1, mistral, qwen2.5, codestral
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Web Panel ──
GUARDX_SECRET_KEY=change-me
# GUARDX_PORT=5000

# ── Auth (bcrypt recommended) ──
# GUARDX_AUTH_ENABLED=true        # Enable/disable login (default: true)
# GUARDX_USER=admin               # Admin username
# GUARDX_PASSWORD=guardx2026      # Plain text or bcrypt hash ($2b$...)
# GUARDX_HTTPS=false              # Set true if using HTTPS (enables Secure cookie)
# To pre-hash password: python3 -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"

# ── Webhooks (optional) ──
# GUARDX_WEBHOOK_SLACK=https://hooks.slack.com/services/xxx
# GUARDX_WEBHOOK_DISCORD=https://discord.com/api/webhooks/xxx
# GUARDX_WEBHOOK_GENERIC=https://your-server.com/webhook
# GUARDX_WEBHOOK_TELEGRAM_TOKEN=xxx
# GUARDX_WEBHOOK_TELEGRAM_CHAT_ID=xxx
